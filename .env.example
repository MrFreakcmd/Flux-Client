# Flux Client environment

# Public URLs
FRONTEND_URL=https://client.example.com
BACKEND_PUBLIC_URL=https://api.client.example.com
# CasaOS-friendly data root for Postgres and Redis
FLUX_DATA_DIR=/DATA/AppData/flux-client
# Optional override for a separate API domain. Leave blank to use same-origin /api.
VITE_API_BASE_URL=
# GitHub Container Registry namespace for the published images, in lowercase
FLUX_GHCR_OWNER=mrfreakcmd
# Optional override for the tags/ports used by Compose
FLUX_IMAGE_TAG=latest
FLUX_BACKEND_PORT=8010
FLUX_FRONTEND_PORT=3010

# Discord OAuth
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=https://api.client.example.com/api/auth/callback

# Calagopus panel
CALAGOPUS_URL=http://host.docker.internal:8080
CALAGOPUS_API_KEY=your_calagopus_admin_api_key

# App security
SECRET_KEY=generate_a_long_random_secret
VPNAPI_KEY=

# Billing
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_SANDBOX=true

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Tuning
AFK_REWARD_PER_HEARTBEAT=1.0
REFERRAL_REWARD_COINS=5.0
DRIFT_SYNC_INTERVAL_SECONDS=900
