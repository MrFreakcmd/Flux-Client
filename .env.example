# Flux Client environment

# Public URLs - Update these to your actual domain
FRONTEND_URL=https://your-client-domain.com
BACKEND_PUBLIC_URL=https://your-client-domain.com
# CasaOS-friendly data root for Postgres and Redis
FLUX_DATA_DIR=/DATA/AppData/flux-client
# Optional override for a separate API domain. Leave blank to use same-origin /api.
# Usually set to the same as BACKEND_PUBLIC_URL when API is served from same domain
VITE_API_BASE_URL=https://your-client-domain.com
# GitHub Container Registry namespace for the published images, in lowercase
FLUX_GHCR_OWNER=mrfreakcmd
# Optional override for the tags/ports used by Compose
FLUX_IMAGE_TAG=latest
FLUX_BACKEND_PORT=8010
FLUX_FRONTEND_PORT=3010

# Optional: Earnings/Rewards System
# Discord guild for join-for-reward feature (requires both guild ID and bot token)
DISCORD_REWARD_GUILD_ID=
# Discord bot token for checking guild membership
DISCORD_BOT_TOKEN=
# Comma-separated list of link reward providers (e.g., "twitter,discord,youtube")
LINK_REWARD_PROVIDERS=

# Discord OAuth - REQUIRED
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
# Must match exactly with the redirect URI registered in your Discord app
DISCORD_REDIRECT_URI=https://your-client-domain.com/api/auth/callback

# Calagopus panel
CALAGOPUS_URL=http://host.docker.internal:8080
CALAGOPUS_API_KEY=your_calagopus_admin_api_key

# App security
SECRET_KEY=generate_a_long_random_secret
VPNAPI_KEY=

# Billing
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_SANDBOX=true

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Tuning
AFK_REWARD_PER_HEARTBEAT=1.0
REFERRAL_REWARD_COINS=5.0
DRIFT_SYNC_INTERVAL_SECONDS=900
